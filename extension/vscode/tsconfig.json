{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": [
      "ES2020",
      "dom"
    ],
    "types": ["node"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node16"
  },
  "include": [
    "extension.ts",
    "json/**/*.json"
  ],
  "exclude": [
    "node_modules",
    "build"
  ]
}
