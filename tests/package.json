{
  "name": "tests",
  "private": true,
  "version": "3.9.70",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "socket-patch": "socket patch scan",
    "type-check": "cd ../ && npx --yes tsc --noEmit",
    "tsc": "cd ../ && npx --yes tsc -b",
    "lint": "cd ../ && oxlint --config .oxlintrc.json",
    "test": "cd ../ && vitest --config ./tests/vitest/vitest.config.ts",
    "test:ui": "cd ../ && vitest --ui --config ./tests/vitest/vitest.config.ts",
    "test:run": "cd ../ && vitest run --config ./tests/vitest/vitest.config.ts",
    "pw": "cd ../ && playwright test --config ./tests/playwright/playwright.config.ts",
    "pw:report": "cd ../ && playwright show-report ./tests/playwright/reports",
    "pw:ui": "playwright test --config playwright/playwright.config.ts --ui"
  },
  "devDependencies": {
    "tslib": "^2.8.1",
    "memorio": "4.3.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "browserslist": "^4.28.6",
    "globals": "17.7.0",
    "jsdom": "^29.1.1",
    "oxlint": "^1.74.0",
    "react": "19.2.7",
    "react-dom": "^19.2.7",
    "ts-morph": "28.0.0",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}