{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "checkJs": true,
    "allowJs": true,
    "composite": false,
    "sourceMap": false,
    "incremental": true,
    // "declaration": false,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "importHelpers": true,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "removeComments": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "inlineSourceMap": false,
    "strictNullChecks": false,
    "resolveJsonModule": true,
    "preserveConstEnums": true,
    "allowUmdGlobalAccess": true,
    // "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "resolvePackageJsonExports": false,
    "allowSyntheticDefaultImports": true,
    "strictPropertyInitialization": false,
    "forceConsistentCasingInFileNames": true,
    "tsBuildInfoFile": "./.cache/.tsbuildinfo",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "module": "ESNext",
    "target": "ESNext",
    "jsx": "react-jsx",
    "outDir": "./",
    "paths": {
      "/*": [
        "./*"
      ],
      "/src/*": [
        "./src/*"
      ]
    },
    "lib": [
      "es2022",
      "dom.iterable",
      "dom"
    ],
    "types": [
      "node"
    ]
  },
  "rootDirs": [
    "./"
  ],
  "typeRoots": [
    "node_modules/@types",
    "tests/node_modules/@types",
    "./types/*",
    "node"
  ],
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./**/types/*.d.ts",
    "./**/*.json"
  ],
  "exclude": [
    "node_modules",
    "public",
    "dist",
    "archive",
    ".private",
    ".backup",
    "*old",
    "*OLD",
    "tests/**/*",
    "vite.*"
  ]
}
