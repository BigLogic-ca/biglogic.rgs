{
  "name": "@biglogic/rgs",
  "code": "argis",
  "version": "3.9.56",
  "description": "Argis (RGS) - Reactive Global State: A react state everywhere made easy",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "workspaces": [
    "tests",
    "extension/vscode"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs"
    },
    "./types/*": "./types/*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "copyright": "Dario Passariello",
  "author": "Dario Passariello",
  "contributors": [
    {
      "name": "Dario Passariello",
      "email": "dariopassarielloa@gmail.com"
    },
    {
      "name": "Valeria Cala Scaglitta",
      "email": "valeriacalascaglitta@gmail.com"
    }
  ],
  "keywords": [
    "rgs",
    "gstate",
    "state-management",
    "react",
    "enterprise",
    "hooks",
    "global-state",
    "immer",
    "biglogic",
    "persistence",
    "react-globo-state",
    "argis"
  ],
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/passariello"
    }
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "**/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biglogic-ca/biglogic.rgs.git"
  },
  "bugs": {
    "url": "https://github.com/biglogic-ca/biglogic.rgs/issues"
  },
  "support": {
    "name": "Dario Passariello",
    "url": "https://dario.passariello.ca/",
    "email": "dariopassariello@gmail.com"
  },
  "scripts": {
    "prebuild1": "npm run lint && npm run tsx && npm run test",
    "build": "tsup && npx tsc -p tsconfig.json --emitDeclarationOnly ",
    "build:extension": "cd extension/vscode && vsce package --no-dependencies -o ../../docs/extension/rgs.vsix",
    "watch": "tsup --watch",
    "npm:pack": "npm run build && npm run build:extension && cd dist && npm pack",
    "npm:publish": "npm run build && npm publish ./dist --access public",
    "dev": "npm run generate-imports && node esbuild.config.mjs --watch-and-serve",
    "test": "cd tests && npm run test",
    "lint": "cd tests && npm run lint",
    "tsc": "cd tests && tsc --noEmit",
    "generate-imports": "tsx core/generate-imports.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild-plugin-copy": "2.1.1",
    "esbuild-sass-plugin": "3.7.0",
    "esbuild-scss-modules-plugin": "1.1.1",
    "immer": "11.1.8",
    "memorio": "4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "terser": "5.48.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "overrides": {
